{
  "name": "parkshare-backend",
  "version": "1.0.0",
  "description": "Parkshare - Parking space sharing platform data infrastructure",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "init-db": "node scripts/init-database.js",
    "import-data": "node --max-old-space-size=8192 scripts/import-all-data.js",
    "process-data": "node --max-old-space-size=8192 scripts/process-all-kpis.js",
    "setup": "npm install && npm run init-db && npm run process-data"
  },
  "keywords": ["parkshare", "parking", "data-analysis"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mysql2": "^3.6.5",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "csvtojson": "^2.0.10",
    "iconv-lite": "^0.6.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
