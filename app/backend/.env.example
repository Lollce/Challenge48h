# Parkshare Backend Configuration

# Server
PORT=5000
NODE_ENV=development

# Database (MySQL - Note: adjust the port if not using standard 3306)
DB_HOST=localhost
DB_PORT=3306
DB_USER=parkuser
DB_PASSWORD=parkpass
DB_NAME=parkshare

# Data paths
DATA_DIR=./data
RAW_HOUSEHOLDS_FILE=menages.csv
RAW_CONDOMINIUMS_FILE=rnc-data.csv
RAW_PARKING_FILE=stationnement.csv

# API settings
API_BASE_URL=/api/v1
CORS_ORIGIN=http://localhost:3000
